{
  "name": "sports-logos",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "refresh": "npm run refresh -w server"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
